<?xml version="1.0" encoding="utf-8"?>
<!--
  Polish (pl_PL) localization for the History & Rankings mod.

  A complete translation covering every LOC key in the mod, using the game's own
  Polish terminology (Tura, Era, Cywilizacja, Przywódca, Wynik). Dynamic slots
  like {1_Age} / {2_Civ} are filled at display time with names the base game has
  already localized.
-->
<Database>
    <LocalizedText>
        <Replace Tag="LOC_HTIMELINE_MOD_NAME" Language="pl_PL"><Text>Historia i rankingi</Text></Replace>
        <Replace Tag="LOC_HTIMELINE_MOD_DESC" Language="pl_PL"><Text>Opowiada historię każdej cywilizacji na przestrzeni er — kim był każdy przywódca, jak rozrastały się imperia, generowaną kronikę oraz archiwum, które zapamiętuje i porównuje poprzednie rozgrywki.</Text></Replace>
